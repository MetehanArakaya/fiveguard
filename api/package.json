{
  "name": "fiveguard-api",
  "version": "1.0.0",
  "description": "Fiveguard AI Anti-Cheat API Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "build": "echo 'No build step required'",
    "docker:build": "docker build -t fiveguard-api .",
    "docker:run": "docker run -p 3001:3001 fiveguard-api"
  },
  "dependencies": {
    "express": "^4.18.1",
    "cors": "^2.8.5",
    "helmet": "^5.1.1",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.5.1",
    "express-validator": "^6.14.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^8.5.1",
    "mysql2": "^2.3.3",
    "redis": "^4.2.0",
    "socket.io": "^4.5.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.30.7",
    "axios": "^0.27.2",
    "node-cron": "^3.0.1",
    "winston": "^3.8.1",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.0.1",
    "joi": "^17.6.0",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "uuid": "^8.3.2",
    "crypto": "^1.0.1",
    "nodemailer": "^6.7.7",
    "express-async-errors": "^3.1.1",
    "swagger-jsdoc": "^6.2.1",
    "swagger-ui-express": "^4.5.0",
    "express-openapi-validator": "^4.13.8",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "express-session": "^1.17.3",
    "connect-redis": "^6.1.3",
    "cookie-parser": "^1.4.6",
    "express-fileupload": "^1.4.0",
    "node-fetch": "^2.6.7",
    "form-data": "^4.0.0",
    "ws": "^8.8.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.19",
    "jest": "^28.1.3",
    "supertest": "^6.2.4",
    "eslint": "^8.21.0",
    "eslint-config-node": "^4.1.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^2.7.1",
    "@types/node": "^18.6.3",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "fiveguard",
    "anticheat",
    "fivem",
    "api",
    "nodejs",
    "express",
    "mysql",
    "redis",
    "websocket",
    "ai",
    "security"
  ],
  "author": "Fiveguard Team",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/fiveguard/api.git"
  },
  "bugs": {
    "url": "https://github.com/fiveguard/api/issues"
  },
  "homepage": "https://fiveguard.com",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/config/**",
      "!src/migrations/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "uploads/*",
      "screenshots/*",
      "node_modules/*"
    ],
    "ext": "js,json",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
